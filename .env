# ═══════════════════════════════════════════════════════════════
# SecureStorageInspector — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values for your machine.
# Lines starting with # are comments.
# ═══════════════════════════════════════════════════════════════

# ── ADB ─────────────────────────────────────────────────────────
# Full path to the adb executable.
# On WSL calling Windows: use the .exe in this repo or your SDK path.
# Example (WSL):  /mnt/c/Users/sadik/Documents/project/adbEXE/adb.exe
# Example (native Linux): /usr/bin/adb
ADB_PATH=adb.exe

# ADB device serial — for Genymotion this is usually an IP:port pair.
# Run `adb devices` to find the correct serial.
DEVICE_SERIAL=x.x.x.x:5555

# ── Genymotion ──────────────────────────────────────────────────
# Installation directory of Genymotion (where gmtool.exe lives).
# On WSL: use the /mnt/c/ path (not C:\) so subprocess can find it.
GENYMOTION_PATH=path to gmotion: Program Files/Genymobile/Genymotion

# Name of the virtual machine to use for scans.
# Run: gmtool admin list  to find the exact name.
GENYMOTION_VM_NAME=Google Nexus 5

# Name of the snapshot to restore before every scan.
# Create a clean snapshot in Genymotion: Device → Snapshots → Take.
GENYMOTION_SNAPSHOT_NAME=clean

# ── Storage Paths ───────────────────────────────────────────────
# Directories for temporary files. Relative paths are resolved from
# the project root (apk-scanner/).
UPLOADS_DIR=uploads
DUMPS_DIR=dumps
REPORTS_DIR=reports

# ── Scan Tuning ─────────────────────────────────────────────────
# Number of random UI events the monkey runner fires.
# Higher = more coverage but slower. 500 is a good default.
MONKEY_EVENTS=500

# Maximum seconds to wait for the emulator to boot.
BOOT_TIMEOUT=120

# Maximum seconds for the entire scan pipeline (install → pull).
SCAN_TIMEOUT=300

# Seconds to pause after monkey finishes, letting storage writes flush.
SETTLE_DELAY=10

# Dev mode: skip emulator reset/boot (assumes emulator already running).
# Set to false in production for full scan isolation.
SKIP_EMULATOR_RESET=true

# ── AAPT (optional) ────────────────────────────────────────────
# Path to aapt/aapt2 for extracting package names from APKs.
# Leave blank to use the pure-Python fallback parser.
AAPT_PATH=aapt2.exe

# ── Database (Phase 3) ─────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver for async support).
# Must match the credentials in docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://scanner:scanner_dev_password@localhost:5432/apk_scanner

# ── Redis / Celery (Phase 3) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ── API Server (Phase 3) ──────────────────────────────────────
MAX_UPLOAD_SIZE=104857600
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
API_HOST=127.0.0.1
API_PORT=8000
RATE_LIMIT_UPLOADS=5/minute
